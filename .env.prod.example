# Public entrypoint
# Production DNS: heiditender.ch -> 135.181.149.82
APP_DOMAIN=heiditender.ch
APP_WWW_DOMAIN=www.heiditender.ch
LETSENCRYPT_EMAIL=william.anze.dan@gmail.com
NEXT_PUBLIC_API_BASE=/api/v1
CORS_ALLOWED_ORIGINS=https://heiditender.ch,https://www.heiditender.ch
HEIDI_INTERNAL_SUBNET=172.30.0.0/24

# Public auth/session settings
AUTH_SESSION_SECRET=replace-with-a-long-random-secret
AUTH_PUBLIC_BASE_URL=https://heiditender.ch
AUTH_FRONTEND_BASE_URL=https://heiditender.ch
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
AUTH_GOOGLE_REDIRECT_URI=
AUTH_MICROSOFT_CLIENT_ID=
AUTH_MICROSOFT_CLIENT_SECRET=
AUTH_MICROSOFT_REDIRECT_URI=

# Optional: only fill these when email magic-link login is enabled.
AUTH_MAGIC_LINK_SENDER_EMAIL=
AUTH_RESEND_API_KEY=
AUTH_MAGIC_LINK_BASE_URL=
AUTH_MAGIC_LINK_SUBJECT=Your Heidi Tender sign-in link
AUTH_SESSION_IDLE_TIMEOUT_SECONDS=86400
AUTH_SESSION_ABSOLUTE_TIMEOUT_SECONDS=1209600
AUTH_MAGIC_LINK_TTL_SECONDS=900
AUTH_MAGIC_LINK_REQUESTS_PER_EMAIL_WINDOW=5
AUTH_MAGIC_LINK_REQUESTS_PER_IP_WINDOW=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=900
UVICORN_FORWARDED_ALLOW_IPS=172.30.0.0/24,127.0.0.1

# Edge/origin hardening
NGINX_TLS_CERT_PATH=
NGINX_TLS_KEY_PATH=
NGINX_TRUSTED_PROXY_FILE=/etc/nginx/security/trusted-proxies.conf
NGINX_ORIGIN_ALLOWLIST_FILE=/etc/nginx/security/origin-allowlist.conf
NGINX_ORIGIN_LOCKDOWN_ENABLED=false

# MySQL catalog database
MYSQL_ROOT_PASSWORD=change-me
PIM_MYSQL_CONTAINER=mysql
PIM_MYSQL_HOST=mysql
PIM_MYSQL_PORT=3306
PIM_MYSQL_USER=root
PIM_MYSQL_PASSWORD=change-me
PIM_MYSQL_DB=pim_raw
PIM_SCHEMA_TABLES=vw_bid_products,vw_bid_specs

# PostgreSQL application database
POSTGRES_DB=suisse_bid_match
POSTGRES_USER=suisse
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://suisse:change-me@postgres:5432/suisse_bid_match

# OpenAI runtime
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional runtime switches
CORE_SKIP_KB_BOOTSTRAP=false
PIM_CHECK_TABLE=articles
FORCE_REBUILD=0
